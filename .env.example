# ═══════════════════════════════════════════════════════════════════
# BTC Trading Bot — .env.example
# $200 başlangıç bakiyesi için optimize edilmiş config.
# Kopyala: cp .env.example .env  →  API key'leri doldur  →  başlat.
# ═══════════════════════════════════════════════════════════════════

# ── Exchange ────────────────────────────────────────────────────────
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here
PAPER_MODE=true          # live için false yap (önce paper'da test et!)
LEVERAGE=10              # 10x: $200 margin → 0.02 BTC pozisyon
MARGIN_MODE=isolated     # isolated: kayıp pozisyonla sınırlı, hesap güvende
MAKER_ENTRY=true         # post-only limit entry → %0 fee (vs %0.01 taker)

# ── Trading ─────────────────────────────────────────────────────────
SYMBOL=BTC/USDT:USDT
# $200 için sadece BTC. Birden fazla coin için bakiye büyüyünce açılır.
# SYMBOLS=BTC,ETH,SOL
PRIMARY_TF=1h
CONFIRM_TF=4h

# ── Strateji Filtreleri ─────────────────────────────────────────────
VOL_FILTER_ENABLED=true

# Funding rate monitor (LIVE-ONLY, işlemi etkilemez, sadece veri toplar)
FUNDING_ENABLED=false
FUNDING_MODE=monitor
FUNDING_EXTREME=0.0005

# Order-flow collector (LIVE-ONLY, işlemi etkilemez, sadece veri toplar)
ORDERFLOW_ENABLED=false
ORDERFLOW_MODE=monitor
ORDERFLOW_WINDOW_MIN=15

# ── 4 Strateji (hepsi backtest'te pozitif TR+TE) ───────────────────
# BB Mean Reversion: PF 1.24 +%28/yıl (ana strateji)
# ORB (NY açılışı 14:00 UTC): PF 1.44 +%23/yıl
# Asia BO (Londra 08:00 UTC): PF 2.15 +%14/yıl
# S/R Breakout (güçlü seviye kırılımı): PF 1.72 +%22/yıl
ORB_ENABLED=true
ASIA_BO_ENABLED=true
SR_BREAKOUT_ENABLED=true

# ── Risk (AGRESİF profil — yüzde-bazlı bileşik büyüme) ──────────────
# research_optimal_200.py: gerçek $200 hesap + margin kısıtı + aylık ekleme
# simülasyonunda test edildi. Agresif profil seçildi:
#   BB %8 / ORB %5 / Asia %3 risk → PF 1.56, maxDD ~%49
# UYARI: maxDD %49 = hesap tepe noktasından yarıya inebilir. Backtest getirileri
# bileşik patlamasıdır; gerçek sonuç bunun kesri olur. Önce paper'da doğrula.
#
# FIXED_MARGIN_USDT=0 → yüzde-bazlı sizing aktif (sabit margin KAPALI). Sabit
# margin BB'yi tüm sermayeyi yemeye zorlardı, ORB/Asia hiç açılamazdı.
FIXED_MARGIN_USDT=0
MAX_RISK_PCT=0.08        # BB mean-rev + S/R breakout risk %'si (bakiyenin)
# POSITION_CAP_FRACTION=10: max notional = bakiye × 10 = tam kaldıraç sınırı.
# (1.0 olsaydı notional bakiyeyle sınırlı kalır, %8 risk sizing ezilirdi.)
POSITION_CAP_FRACTION=10.0

ATR_SL_MULT=3.0
RR_RATIO=1.667           # TP = 5×ATR (SL × 1.667 = 5×ATR/3×ATR)

# Ayrı sermaye modeli: BB (slot=symbol) + ORB (slot=symbol:orb) + Asia (slot=symbol:asia_bo)
# aynı anda açık olabilir. Her strateji kendi slotunu kullanır → birbirini bloke etmez.
# S/R breakout BB ile aynı slotu paylaşır (her ikisi de 48h swing); yalnızca BB boşken açılır.
MAX_POSITIONS=3

SNIPER_MIN_GRADE=0
# 35%: BB SL'i %30 kayıp → 1 kayıptan sonra 1 trade daha açılabilir,
# 2 üst üste kayıptan sonra gün için trading durur.
DAILY_MAX_LOSS_PCT=0.35
MAX_HOLD_CANDLES=48

# Intraday (ORB/Asia BO): ayrı pozisyon slotu, 6 saatte kapanır.
# Her sleeve kendi risk %'si (agresif profil): ORB en güçlü (PF 2.29), sonra Asia.
ORB_RISK_PCT=0.05        # ORB: serbest bakiyenin %5'i risk
ASIA_RISK_PCT=0.03       # Asia BO: serbest bakiyenin %3'i risk
DAY_RISK_PCT=0.05        # yedek (per-sleeve ayarlanmamışsa)
DAY_MAX_HOLD_CANDLES=6
CONFIDENCE_SIZING=false

# ── Trade Yönetimi (Trailing Stop) ──────────────────────────────────
# 1×ATR karda SL entry'ye gelir (bedava trade). Peak - 2×ATR trailing.
TRAILING_STOP_ENABLED=true
BREAKEVEN_ATR_MULT=1.0
TRAILING_ATR_MULT=2.0

# ── Rejim Filtresi (ADX) ────────────────────────────────────────────
# Trending (ADX>28) → BB baskılı (trend karşı trade kaybettirir).
# Ranging  (ADX<20) → ORB/S/R baskılı (yalancı kırılım oranı artar).
REGIME_FILTER_ENABLED=true
ADX_TRENDING_THRESHOLD=28
ADX_RANGING_THRESHOLD=20

# ── Ardışık Kayıp Koruması ──────────────────────────────────────────
# Her strateji sleeve'i bağımsız sayar (BB 2 kayıp, ama ORB 1 galibiyet BB sayacını sıfırlamaz).
# Herhangi bir sleeve limiti aştığında global cooldown başlar.
CONSECUTIVE_LOSS_LIMIT=2
COOLDOWN_MINUTES=240

# ── Hafta sonu / Haftaiçi Yönlendirme ───────────────────────────────
# Araştırma: BB haftaiçi PF ~0.97 (negatif edge), weekend PF daha yüksek.
# ORB hafta sonu PF 3.22 vs genel 1.44 — haftasonu ORB büyüklüğünü artır.
# BUG-3 düzeltmesiyle ADX>28 trending rejimde BB zaten baskılanır.
# Daha agresif filtreleme için BB_WEEKDAY_ENABLED=false yapılabilir.
BB_WEEKDAY_ENABLED=true      # false → BB Pazartesi–Cuma hiç açılmaz
ORB_WEEKEND_MULT=1.5         # haftasonu ORB risk = ORB_RISK_PCT × 1.5 (maks %8)

# ── Paper Trading ───────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=200.0

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── App ─────────────────────────────────────────────────────────────
DB_PATH=./trades.db
LOG_LEVEL=INFO
HEARTBEAT_HOURS=6
