# Exchange
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here
PAPER_MODE=true
LEVERAGE=30
MARGIN_MODE=isolated
# MAKER_ENTRY: use post-only limit entries (0% maker fee vs 0.01% taker).
# Worth ~+6%/yr in backtest by cutting transaction cost. Falls back to market
# if the limit doesn't fill within ~45s.
MAKER_ENTRY=true

# Trading (validated edge is 1h Bollinger mean reversion)
SYMBOL=BTC/USDT:USDT
# Multi-coin: comma-separated list. Overrides SYMBOL. Accepts "BTC",
# "BTC/USDT" or "BTC/USDT:USDT" (auto-normalized to the MEXC perp form).
# Each coin gets its own data feed + strategy but shares one balance.
# Leave empty to trade only SYMBOL. Validated edge is BTC; others are still
# being forward-tested by paper_scanner — only promote coins that prove out.
# SYMBOLS=BTC,ETH,SOL,BNB,XRP
PRIMARY_TF=1h
CONFIRM_TF=4h

# Strategy filters
# VOL_FILTER_ENABLED: require above-average volume on BB extreme candle
# (filters quiet drift signals; keeps genuine exhaustion/capitulation entries)
VOL_FILTER_ENABLED=true

# Funding rate / open interest monitoring (LIVE-ONLY — cannot be backtested,
# since historical funding is not in the OHLCV CSVs). Theory: extreme funding
# = crowded positioning = squeeze fuel for the mean-reversion fade.
#   FUNDING_ENABLED=false : off (default — does not touch the validated edge)
#   FUNDING_MODE=monitor  : log funding+OI on every signal to build a dataset
#                           (run this for a few weeks FIRST to validate)
#   FUNDING_MODE=filter   : additionally skip contrarian+extreme setups
#   FUNDING_MODE=boost    : nudge position confidence by funding alignment
# FUNDING_EXTREME: |funding| per interval above which positioning is "crowded"
#                  (0.0005 = 0.05% per 8h funding interval)
FUNDING_ENABLED=false
FUNDING_MODE=monitor
FUNDING_EXTREME=0.0005

# Order-flow collector (LIVE-ONLY, monitor-first — cannot be backtested).
# When ON, opens ONE watchTrades feed on the primary symbol and logs taker
# delta + order-book depth imbalance for every 1h signal to orderflow_log.csv.
# It NEVER affects trades — it only builds a forward dataset so we can later
# check whether order flow adds edge to OUR signals before trading on it.
# Leave OFF while validating the core strategy; turn ON to start collecting.
ORDERFLOW_ENABLED=false
ORDERFLOW_MODE=monitor
ORDERFLOW_WINDOW_MIN=15

# Intraday breakout strategies (day-trading sleeves alongside the 1h BB core)
# ORB: NY session 60-min opening range breakout (PF 1.44, WR 51%, +23%)
# Asia BO: Asia session range → London/NY breakout (PF 2.15, WR 59%, +14%)
# Both fire at most once per day; both are disabled if a BB position is open.
ORB_ENABLED=true
ASIA_BO_ENABLED=true
# S/R breakout: swing momentum on strong levels (3+ touches) + volume/body
# confirmation. Validated: lb80 touch3 SL3ATR RR3.0 → PF 1.72, +22%, DD 4.2%.
# Uses the normal 48h max-hold + full risk (it's a swing trade, not intraday).
SR_BREAKOUT_ENABLED=true

# Risk (validated parameters: SL=3xATR, TP=5xATR, max 48h hold)
# MAX_RISK_PCT: 0.02 (safe) → +27%/yr; 0.03 (recommended) → +28%/yr same maxDD.
# Above ~4% the 50%-of-balance position cap binds, so returns plateau but tail
# risk on a single trade keeps rising. 0.03 is the sweet spot.
# MAX_RISK_PCT + POSITION_CAP_FRACTION together determine aggressiveness.
# Backtest (BB only, 12mo): 3%+0.5x=+1.7%/mo DD11% | 8%+1.0x=+3.2%/mo DD21%
# Beyond 8%+1x returns flatten and DD spikes → not worth it.
# Optimum risk parameters (backtest, 12mo BTC):
# Calmar ratio (monthly/maxDD) is constant regardless of leverage — scaling
# position size scales both return AND drawdown proportionally. Best Calmar
# is at lower notional fractions; 1.5x is the sweet spot: +4.5%/mo, DD 30%.
# MAX_RISK_PCT is set high so POSITION_CAP_FRACTION is always the binding cap.
# Effective risk per trade = cap × balance / (entry × sl_dist_pct) ≈ 4.5%.
MAX_RISK_PCT=0.15
POSITION_CAP_FRACTION=1.5
ATR_SL_MULT=3.0
RR_RATIO=1.667
# Portfolio-wide cap on concurrent open positions (one per coin max anyway).
# 4 strategies across 5 coins → 3 allows meaningful diversification while
# keeping worst-case exposure at ~7% (2×BB/SR @3% + 1×intraday @1%).
MAX_POSITIONS=3
# SNIPER_MIN_GRADE: 0=off, 2=require 2/3 confluences (ATR%+overshoot+VWAP). Reduces
# trade count ~40% but improves win rate from 47% to ~52% (research_sniper.py).
SNIPER_MIN_GRADE=0
DAILY_MAX_LOSS_PCT=0.05
MAX_HOLD_CANDLES=48
# Day-trading sleeves (ORB, Asia BO): smaller risk + shorter max hold so they
# don't lock up capital overnight. Separate from the 1h BB swing risk.
DAY_RISK_PCT=0.01
DAY_MAX_HOLD_CANDLES=6
# CONFIDENCE_SIZING: scale position size down on weaker signals (never above the
# validated full risk). Off by default so it doesn't disturb the proven edge.
CONFIDENCE_SIZING=false

# Paper Trading
# Minimum recommended balance: ~$200 at current BTC ATR levels.
# With MEXC's 0.001 BTC minimum order, the bot needs enough capital so that
# 2% risk × balance is large enough to reach the minimum position size.
# At BTC=$100k with ATR≈1%: minimum balance ≈ $150.
# With LEVERAGE=30 the margin requirement drops (~$3 per 0.001 BTC contract)
# but RISK per trade in dollar terms stays the same — leverage only reduces
# the margin tied up, not the loss if SL is hit.
PAPER_INITIAL_BALANCE=10000.0

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# App
DB_PATH=./trades.db
LOG_LEVEL=INFO
# HEARTBEAT_HOURS: how often the bot sends a Telegram "still alive" message
# (it also touches /tmp/bot_alive every 5 min for external healthchecks).
HEARTBEAT_HOURS=6
