# ═══════════════════════════════════════════════════════════════════
# BTC Trading Bot — .env.example
# $200 başlangıç bakiyesi için optimize edilmiş config.
# Kopyala: cp .env.example .env  →  API key'leri doldur  →  başlat.
# ═══════════════════════════════════════════════════════════════════

# ── Exchange ────────────────────────────────────────────────────────
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here
PAPER_MODE=true          # live için false yap (önce paper'da test et!)
LEVERAGE=10              # 10x: $200 margin → 0.02 BTC pozisyon
MARGIN_MODE=isolated     # isolated: kayıp pozisyonla sınırlı, hesap güvende
MAKER_ENTRY=true         # post-only limit entry → %0 fee (vs %0.01 taker)

# ── Trading ─────────────────────────────────────────────────────────
SYMBOL=BTC/USDT:USDT
# $200 için sadece BTC. Birden fazla coin için bakiye büyüyünce açılır.
# SYMBOLS=BTC,ETH,SOL
PRIMARY_TF=1h
CONFIRM_TF=4h

# ── Strateji Filtreleri ─────────────────────────────────────────────
VOL_FILTER_ENABLED=true

# Funding rate monitor (LIVE-ONLY, işlemi etkilemez, sadece veri toplar)
FUNDING_ENABLED=false
FUNDING_MODE=monitor
FUNDING_EXTREME=0.0005

# Order-flow collector (LIVE-ONLY, işlemi etkilemez, sadece veri toplar)
ORDERFLOW_ENABLED=false
ORDERFLOW_MODE=monitor
ORDERFLOW_WINDOW_MIN=15

# ── 4 Strateji (hepsi backtest'te pozitif TR+TE) ───────────────────
# BB Mean Reversion: PF 1.24 +%28/yıl (ana strateji)
# ORB (NY açılışı 14:00 UTC): PF 1.44 +%23/yıl
# Asia BO (Londra 08:00 UTC): PF 2.15 +%14/yıl
# S/R Breakout (güçlü seviye kırılımı): PF 1.72 +%22/yıl
ORB_ENABLED=true
ASIA_BO_ENABLED=true
SR_BREAKOUT_ENABLED=true

# ── Risk ($200 için optimize) ───────────────────────────────────────
# FIXED_MARGIN_USDT: her trade'de tam bu kadar margin kullan (değişmez).
# Backtest: $200 sabit margin × LEVERAGE=10 → +%14.9/ay, DD %55, Calmar 0.27
# Yüzde bazlı pozisyon boyutlamasından daha iyi Calmar çünkü bakiye büyüse
# bile kayıplar sabit kalır — bileşik çöküşü engeller.
FIXED_MARGIN_USDT=200
MAX_RISK_PCT=0.20        # S/R breakout için yedek (FIXED_MARGIN_USDT geçersiz kılar BB için)
POSITION_CAP_FRACTION=1.0

ATR_SL_MULT=3.0
RR_RATIO=1.667           # TP = 5×ATR (SL × 1.667 = 5×ATR/3×ATR)

# Ayrı sermaye modeli: BB (slot=symbol) + ORB (slot=symbol:orb) + Asia (slot=symbol:asia_bo)
# aynı anda açık olabilir. Her strateji kendi slotunu kullanır → birbirini bloke etmez.
# S/R breakout BB ile aynı slotu paylaşır (her ikisi de 48h swing); yalnızca BB boşken açılır.
MAX_POSITIONS=3

SNIPER_MIN_GRADE=0
# 35%: BB SL'i %30 kayıp → 1 kayıptan sonra 1 trade daha açılabilir,
# 2 üst üste kayıptan sonra gün için trading durur.
DAILY_MAX_LOSS_PCT=0.35
MAX_HOLD_CANDLES=48

# Intraday (ORB/Asia BO): küçük pozisyon, 6 saatte kapanır
DAY_RISK_PCT=0.05        # %5 = $10 risk (küçük intraday pozisyon)
DAY_MAX_HOLD_CANDLES=6
CONFIDENCE_SIZING=false

# ── Trade Yönetimi (Trailing Stop) ──────────────────────────────────
# 1×ATR karda SL entry'ye gelir (bedava trade). Peak - 2×ATR trailing.
TRAILING_STOP_ENABLED=true
BREAKEVEN_ATR_MULT=1.0
TRAILING_ATR_MULT=2.0

# ── Rejim Filtresi (ADX) ────────────────────────────────────────────
# Trending (ADX>28) → BB baskılı. Ranging (ADX<20) → ORB/S/R baskılı.
REGIME_FILTER_ENABLED=true
ADX_TRENDING_THRESHOLD=28
ADX_RANGING_THRESHOLD=20

# ── Ardışık Kayıp Koruması ──────────────────────────────────────────
# 2 üst üste kayıp → 4 saat cooldown, yeni trade alınmaz.
CONSECUTIVE_LOSS_LIMIT=2
COOLDOWN_MINUTES=240

# ── Paper Trading ───────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=200.0

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── App ─────────────────────────────────────────────────────────────
DB_PATH=./trades.db
LOG_LEVEL=INFO
HEARTBEAT_HOURS=6
