# Exchange
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here
PAPER_MODE=true
LEVERAGE=10
MARGIN_MODE=isolated

# Trading
SYMBOL=BTC/USDT:USDT
PRIMARY_TF=5m
CONFIRM_TF=15m

# Risk
MAX_RISK_PCT=0.02
ATR_SL_MULT=1.5
RR_RATIO=2.0
MAX_POSITIONS=1
DAILY_MAX_LOSS_PCT=0.05

# Paper Trading
PAPER_INITIAL_BALANCE=10000.0

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# App
DB_PATH=./trades.db
LOG_LEVEL=INFO
